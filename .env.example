# Database — SQLite (dev) or PostgreSQL (production)
# SQLite example:
DATABASE_URL="file:./dev.db"
# PostgreSQL example (after migration):
# DATABASE_URL="postgresql://ula_app:STRONG_PASSWORD@localhost:5432/ula?schema=public"

# Prisma provider must match DATABASE_URL — run after changing:
#   npm run db:use:sqlite    (for file:./ URLs)
#   npm run db:use:postgres  (for postgresql:// URLs)
DEFAULT_INSTITUTION_SLUG=ibbul

# Local demo institution users (development only — never in production)
# SEED_DEMO_ACCOUNTS=true   # force demo seed; default true in dev, false in production

NODE_ENV=development

# JWT secrets — generate with: npm run jwt:generate
# Development: placeholder below works; production requires 64+ char random secrets (see .env.production.example)
JWT_SECRET="change-this-to-a-long-random-string-in-production"
# Platform operators (optional in dev — falls back to JWT_SECRET; required separate secret in production)
# PLATFORM_JWT_SECRET=

# ─── Cloudinary (REQUIRED for all file uploads) ───
# See CLOUDINARY.md for setup + testing
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="ula_files"
SIGNED_URL_TTL_SEC=900

# Upload & rate limits
UPLOAD_MAX_PER_USER_HOUR=30
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_UPLOAD_MAX=30
RATE_LIMIT_BACKUP_MAX=5

# Daily SQLite backup → Cloudinary ula_backups/ (02:00 local)
BACKUP_CRON_ENABLED=true
BACKUP_CRON_SCHEDULE="0 2 * * *"

# Retention: keep 7 daily + 4 weekly + 12 monthly snapshots
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=12

# Off-site copy (outside app directory — required in production)
# Dev: defaults to ../ula-backups if unset
BACKUP_OFFSITE_DIR=
BACKUP_RCLONE_REMOTE=

# Weekly restore validation (Sunday 03:00) — dry-run integrity check
BACKUP_VALIDATE_ENABLED=true
BACKUP_VALIDATE_CRON="0 3 * * 0"

# Public URLs
# Development:
APP_PUBLIC_URL=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:4000
# Production (REQUIRED — all three must be https://, see deploy/HTTPS.md):
# CLIENT_ORIGIN=https://ula.yourdomain.com
# APP_PUBLIC_URL=https://ula.yourdomain.com
# PUBLIC_BASE_URL=https://ula.yourdomain.com
# HOST=127.0.0.1
# neo db
DATABASE_URL="postgresql://neondb_owner:npg_YDsuS14tHXrU@ep-hidden-base-adv86h9t-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# ─── Email — SendGrid SMTP (see SENDGRID_SETUP.md) ───
# Dev: leave SMTP_HOST empty → emails saved to data/email-outbox/
# Prod: required — server exits if SMTP is missing in NODE_ENV=production
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=
SMTP_FROM="ULA Platform <noreply@yourdomain.com>"
SMTP_REPLY_TO=support@yourdomain.com
SMTP_FROM_NAME=ULA Platform
# Never enable in production — sandbox only delivers to verified addresses
SENDGRID_SANDBOX=false
SMTP_RETRY_MAX=3
SMTP_RETRY_DELAY_MS=1000
# Dev: mirror every sent email to data/email-outbox/ (reset links work even if SendGrid lands in spam)
EMAIL_DEV_OUTBOX=true
EMAIL_MIRROR_OUTBOX=true
EMAIL_TEST_TO=

PORT=4000
CLIENT_ORIGIN=http://localhost:5173
