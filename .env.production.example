# ULA Production Environment — copy to .env on server
# Boot: npm run start:production  (validates config → prisma migrate deploy → API)
# PM2:  args use start:production — see deploy/pm2/ecosystem.config.cjs
# All public URLs MUST use https:// (server exits on boot if not)

NODE_ENV=production
HOST=0.0.0.0
PORT=4000

# PostgreSQL (required in production — SQLite file: URLs are rejected at boot)
DATABASE_URL="postgresql://ula_app:REPLACE_PASSWORD@127.0.0.1:5432/ula?schema=public"
# Generate both: npm run jwt:generate  (minimum 64 characters each; must differ)
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
PLATFORM_JWT_SECRET=REPLACE_WITH_SEPARATE_64_CHAR_RANDOM_STRING

# ─── HTTPS public URLs (all three required, must match Nginx server_name) ───
CLIENT_ORIGIN=https://ula.yourdomain.com
APP_PUBLIC_URL=https://ula.yourdomain.com
PUBLIC_BASE_URL=https://ula.yourdomain.com

# ─── Cloudinary (required in production) ───
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=ula_files
SIGNED_URL_TTL_SEC=900

# ─── Email (required in production) ───
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=
SMTP_FROM="ULA Platform <noreply@yourdomain.com>"
SMTP_REPLY_TO=support@yourdomain.com
SMTP_FROM_NAME=ULA Platform
SENDGRID_SANDBOX=false
SMTP_RETRY_MAX=3
SMTP_RETRY_DELAY_MS=1000
EMAIL_DEV_OUTBOX=false
EMAIL_MIRROR_OUTBOX=false

# ─── Backup ───
BACKUP_CRON_ENABLED=true
BACKUP_CRON_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=12
BACKUP_VALIDATE_ENABLED=true
BACKUP_VALIDATE_CRON="0 3 * * 0"

# ─── Rate limits ───
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_UPLOAD_MAX=30
RATE_LIMIT_BACKUP_MAX=5
UPLOAD_MAX_PER_USER_HOUR=30

DEFAULT_INSTITUTION_SLUG=ibbul
